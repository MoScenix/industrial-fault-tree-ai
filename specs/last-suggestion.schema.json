{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "last-suggestion/v1",
  "title": "LastSuggestionFile",
  "type": "object",
  "required": [
    "based_on_version",
    "created_at",
    "summary",
    "node_suggestions",
    "edge_suggestions",
    "general_suggestions"
  ],
  "properties": {
    "based_on_version": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "node_suggestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/suggestion" }
    },
    "edge_suggestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/suggestion" }
    },
    "general_suggestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/suggestion" }
    }
  },
  "$defs": {
    "suggestion": {
      "type": "object",
      "required": [
        "target_type",
        "target_id",
        "action",
        "reason",
        "evidence_chunk_ids"
      ],
      "properties": {
        "target_type": { "type": "string" },
        "target_id": { "type": "string" },
        "action": { "type": "string" },
        "reason": { "type": "string" },
        "evidence_chunk_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
